{
  "openapi": "3.0.1",
  "info": {
    "title": "Yad2",
    "version": "1.0"
  },
  "paths": {
    "/api/Advertisement/CreateAdvertisement": {
      "post": {
        "tags": [
          "Advertisement"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Advertisement/GetAdvertisement/{id}": {
      "get": {
        "tags": [
          "Advertisement"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Advertisement/GetAdvertisements": {
      "get": {
        "tags": [
          "Advertisement"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Advertisement/UpdateAdvertisement/{id}": {
      "put": {
        "tags": [
          "Advertisement"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertisementDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
