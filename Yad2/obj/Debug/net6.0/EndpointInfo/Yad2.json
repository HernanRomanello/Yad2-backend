      "post": {
        "tags": [
          "Users"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
