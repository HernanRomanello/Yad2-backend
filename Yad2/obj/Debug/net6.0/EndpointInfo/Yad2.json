  "components": {
    "schemas": {
      "AddressDto": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "nullable": true
          },
          "street": {
            "type": "string",
            "nullable": true
          },
          "number": {
            "type": "integer",
            "format": "int32"
          },
          "floor": {
            "type": "integer",
            "format": "int32"
          },
          "totalFloors": {
            "type": "integer",
            "format": "int32"
          },
          "onPillars": {
            "type": "boolean"
          },
          "neighborhood": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AdvertisementDto": {
        "type": "object",
        "properties": {
          "address": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "assetType": {
            "type": "string",
            "nullable": true
          },
          "assetState": {
            "type": "string",
            "nullable": true
          },
          "airDirections": {
            "type": "integer",
            "format": "int32"
          },
          "view": {
            "type": "string",
            "nullable": true
          },
          "rearProperty": {
            "type": "boolean"
          },
          "accessibleForDisabled": {
            "type": "boolean"
          },
          "airConditioning": {
            "type": "boolean"
          },
          "windowBars": {
            "type": "boolean"
          },
          "solarWaterHeater": {
            "type": "boolean"
          },
          "elevator": {
            "type": "boolean"
          },
          "forRoommates": {
            "type": "boolean"
          },
          "furnished": {
            "type": "boolean"
          },
          "separateUnit": {
            "type": "boolean"
          },
          "kosherKitchen": {
            "type": "boolean"
          },
          "petsAllowed": {
            "type": "boolean"
          },
          "renovated": {
            "type": "boolean"
          },
          "safeRoom": {
            "type": "boolean"
          },
          "multiLockDoors": {
            "type": "boolean"
          },
          "tornadoAirConditioner": {
            "type": "boolean"
          },
          "storageRoom": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "numberOfPayments": {
            "type": "integer",
            "format": "int32"
          },
          "houseCommitteePayment": {
            "type": "number",
            "format": "double"
          },
          "municipalityMonthlyPropertyTax": {
            "type": "number",
            "format": "double"
          },
          "builtSquareMeters": {
            "type": "integer",
            "format": "int32"
          },
          "gardenSquareMeters": {
            "type": "number",
            "format": "double"
          },
          "totalSquareMeters": {
            "type": "number",
            "format": "double"
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "minimumAmount": {
            "type": "integer",
            "format": "int32"
          },
          "pricePerMeter": {
            "type": "number",
            "format": "double"
          },
          "entryDate": {
            "type": "integer",
            "format": "int64"
          },
          "immediate": {
            "type": "boolean"
          },
          "flexible": {
            "type": "boolean"
          },
          "longTerm": {
            "type": "boolean"
          },
          "pictures": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "video": {
            "type": "string",
            "nullable": true
          },
          "contactName": {
            "type": "string",
            "nullable": true
          },
          "contactPhone": {
            "type": "string",
            "nullable": true
          },
          "standardizationAccepted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "SignUpModel": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "confirmPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
